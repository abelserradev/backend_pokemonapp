# ===========================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ===========================================
# Copia este archivo como .env.local para desarrollo
# o configura estas variables en tu plataforma de despliegue

# Base de datos
# Para desarrollo local (SQLite):
DATABASE_URL=sqlite:///./pokemon_local.db

# Para producción (MySQL):
# DATABASE_URL=mysql+pymysql://usuario:password@host:puerto/database

# Configuración de seguridad
SECRET_KEY=tu-clave-secreta-super-segura

# Configuración CORS
# Para desarrollo:
ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Para producción:
# ALLOWED_ORIGINS=https://tu-frontend.vercel.app

# Puerto del servidor
PORT=8000

# Entorno
ENVIRONMENT=development
# ENVIRONMENT=production

# Docker Compose (producción): ver .env.production.example y docker-compose.yml
