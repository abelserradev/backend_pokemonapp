# Copiar a .env en la misma carpeta que docker-compose.yml para `docker compose up`
# (el archivo .env no se sube a git). En Coolify define estas mismas claves en el panel.
#
# DATABASE_URL: MySQL (PyMySQL). Coolify suele dar mysql://...; el código convierte a mysql+pymysql://
DATABASE_URL=mysql+pymysql://usuario:password@host-mysql-interno:3306/nombre_bd

# JWT / sesiones
SECRET_KEY=genera-con-openssl-rand-hex-32

# CORS: origen del front en producción (coma si hay varios, sin espacios extra)
ALLOWED_ORIGINS=https://pokemon.buildforge.work

# Puerto interno del contenedor (alineado con Traefik / sin bind en host en compose)
PORT=3000

ENVIRONMENT=production
